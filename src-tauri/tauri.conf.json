{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Fihirana Jesosy Mpanafaka",
  "version": "1.0.0",
  "identifier": "com.fihirana.offline",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Fihirana Jesosy Mpanafaka",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/ezdev2/fihirana-offline/main/update.json"
      ]
    }
  }
}
